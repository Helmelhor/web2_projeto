<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <style>
    /* Suas variáveis e estilos do topo permanecem os mesmos... */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --orange-primary: #FF8C00; --orange-dark: #E67E00; --orange-light: #FFB84D;
      --dark-bg: #0F1419; --card-bg: #1A1F2E; --text-light: #E0E0E0; --text-muted: #A0A0A0;
    }
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: var(--dark-bg); color: var(--text-light); line-height: 1.6; }
    
    .navbar { background: rgba(15, 20, 25, 0.9); border-bottom: 1px solid #2F3336; position: sticky; top: 0; z-index: 100; padding: 1rem 0; }
    .nav-content { max-width: 650px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding: 0 1rem; }
    .nav-logo { font-size: 1.5rem; font-weight: bold; color: white; text-decoration: none; display: flex; align-items: center; gap: 0.5rem; }
    .timeline { max-width: 650px; margin: 0 auto; border-left: 1px solid #2F3336; border-right: 1px solid #2F3336; min-height: 100vh; }
    
    /* Post Box & Forms */
    .create-post-box { padding: 1.5rem; border-bottom: 1px solid #2F3336; }
    .create-header { display: flex; gap: 1rem; margin-bottom: 1rem; }
    .avatar { width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, var(--orange-primary), var(--orange-dark)); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; font-weight: bold; flex-shrink: 0; }
    .create-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; flex-grow: 1; }
    .full-width { grid-column: span 2; }
    .form-control { width: 100%; padding: 0.8rem 1rem; background: var(--dark-bg); border: 1px solid #2F3336; border-radius: 12px; color: var(--text-light); outline: none; }
    .form-control:focus { border-color: var(--orange-primary); }
    .btn { padding: 0.6rem 1.5rem; border: none; border-radius: 50px; font-weight: bold; cursor: pointer; transition: 0.2s; }
    .btn-primary { background: var(--orange-primary); color: white; }
    .btn-primary:hover { background: var(--orange-dark); }
    .create-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; padding-left: calc(48px + 1rem); }
    
    /* Posts */
    .post { padding: 1.5rem; border-bottom: 1px solid #2F3336; display: flex; gap: 1rem; }
    .post-content { flex-grow: 1; min-width: 0; }
    .post-author-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
    .author-name { font-weight: bold; font-size: 1rem; color: white; }
    .author-handle { color: var(--text-muted); font-weight: normal; font-size: 0.9rem; }
    .post-options a { color: var(--text-muted); text-decoration: none; font-size: 0.8rem; margin-left: 0.8rem; cursor: pointer;}
    .post-options a:hover { color: var(--orange-primary); }
    .post-options a.danger:hover { color: #f4212e; }
    .post-text { font-size: 0.95rem; margin-bottom: 1rem; }
    .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
    .tag { background: rgba(255, 140, 0, 0.1); color: var(--orange-primary); padding: 0.2rem 0.8rem; border-radius: 20px; font-size: 0.8rem; border: 1px solid rgba(255, 140, 0, 0.2); }
    
    /* Botões Sociais e Likes */
    .social-actions { display: flex; gap: 2rem; margin-top: 1rem; color: var(--text-muted); }
    .inline-form { display: inline; }
    .action-btn { background: transparent; border: none; color: var(--text-muted); font-size: 0.9rem; cursor: pointer; display: flex; align-items: center; gap: 0.3rem; }
    .action-btn:hover { color: var(--orange-primary); }
    .action-btn.liked { color: #f4212e; }

    /* Comentários */
    .comments-section { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px dashed #2F3336; }
    .comment-item { display: flex; gap: 0.8rem; margin-bottom: 1rem; }
    .comment-avatar { width: 32px; height: 32px; border-radius: 50%; background: #22283A; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; }
    .comment-bubble { background: #22283A; padding: 0.8rem 1rem; border-radius: 0 15px 15px 15px; flex-grow: 1; }
    .comment-header { display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 0.3rem; }
    .comment-header strong { color: white; }
    .comment-nota { color: var(--orange-primary); font-weight: bold; }
    .comment-text { font-size: 0.9rem; color: var(--text-light); margin-bottom: 0.5rem;}
    
    /* Área de Resposta (Indentada) */
    .reply-item { margin-left: 2rem; margin-top: 0.5rem; border-left: 2px solid var(--orange-primary); padding-left: 1rem;}

    .new-comment { display: flex; gap: 0.5rem; margin-top: 1rem; align-items: center; }
    .new-comment .form-control { border-radius: 50px; padding: 0.6rem 1.2rem; background: var(--card-bg); }
    .new-comment .nota-select { width: 80px; border-radius: 50px; }
    .btn-send { background: transparent; border: none; color: var(--orange-primary); font-size: 1.2rem; cursor: pointer; padding: 0.5rem; border-radius: 50%;}
  </style>
</head>
<body>

  <nav class="navbar">
    <div class="nav-content">
      <a href="/home/index" class="nav-logo">🏀 Bem vindo <%= current_user.nome %>!!</a>
      <%= link_to "Logout", logout_path, data: { turbo_method: :delete }, class: "btn btn-primary", style: "padding: 0.4rem 1rem; font-size: 0.9rem;" %>
    </div>
  </nav>

  <div class="timeline">
    
    <!-- Formulário Principal -->
    <div class="create-post-box">
      <div class="create-header">
        <div class="avatar"><%= current_user.nome.first.upcase rescue "U" %></div> 
        <%= form_with(model: @quadra || Quadra.new, local: true, class: "full-width") do |f| %>
          <div class="create-form-grid">
            <div class="full-width"><%= f.text_field :nome, class: "form-control", placeholder: "Nome da quadra", required: true %></div>
            <div><%= f.text_field :endereco, class: "form-control", placeholder: "Endereço" %></div>
            <div><%= f.text_field :cidade, class: "form-control", placeholder: "Cidade" %></div>
            <div class="full-width"><%= f.text_area :descricao, class: "form-control", placeholder: "Descreva as condições..." %></div>
            <div><%= f.text_field :tipo_piso, class: "form-control", placeholder: "Piso (Ex: Asfalto)" %></div>
            <div style="display: flex; align-items: center; gap: 0.5rem; padding-left: 0.5rem; font-size: 0.9rem;">
              <%= f.check_box :tem_iluminacao %> <%= f.label :tem_iluminacao, "Tem iluminação?" %>
            </div>
          </div>
          
          <div class="create-footer">
            <!-- Upload: botão separado do input; mostra confirmação quando selecionada -->
            <div class="upload-group" style="display:flex; align-items:center; gap:0.6rem;">
              <button type="button" class="btn btn-primary" onclick="document.getElementById('quadra_foto_input').click()">
                📷 Adicionar Foto
              </button>
              <span id="foto-confirm" style="color: var(--orange-primary); font-size:0.9rem; display:none;">📸 Foto selecionada</span>
              <%= f.file_field :foto, id: "quadra_foto_input", accept: "image/*", style: "display: none;", onchange: "document.getElementById('foto-confirm').style.display='inline'; document.getElementById('foto-confirm').textContent = '📸 ' + (this.files[0] ? this.files[0].name : 'Foto selecionada');" %>
            </div>
            <%= f.submit "Postar", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Feed -->
    <% if @quadras.present? %>
      <% @quadras.order(created_at: :desc).each do |quadra| %>
        <article class="post">
          <div class="avatar"><%= quadra.user.nome.first.upcase rescue "Q" %></div>
          
          <div class="post-content">
            <div class="post-author-row">
              <div class="author-name">
                <%= quadra.user.nome rescue "Usuário" %>
                <span class="author-handle">adicionou <strong><%= quadra.nome %></strong></span><br>
                <span class="author-handle">📍 <%= quadra.cidade %> · <%= time_ago_in_words(quadra.created_at) %> atrás</span>
              </div>
              
              <% if quadra.user == current_user %>
                <div class="post-options">
                  <%= link_to 'Editar', edit_quadra_path(quadra) %>
                  <%= link_to 'Excluir', quadra, data: { turbo_method: :delete, turbo_confirm: 'Deseja apagar?' }, class: "danger" %>
                </div>
              <% end %>
            </div>

            <div class="post-text"><%= quadra.descricao %></div>

            <!-- AQUI EXIBE A FOTO SE ELA EXISTIR -->
            <% if quadra.foto.attached? %>
              <div style="margin-bottom: 1rem; border-radius: 15px; overflow: hidden; border: 1px solid var(--border-color);">
                <%= image_tag quadra.foto, style: "width: 100%; max-height: 400px; object-fit: cover; display: block;" %>
              </div>
            <% end %>

            <div class="post-tags">
              <span class="tag">🛣️ <%= quadra.endereco %></span>
              <% if quadra.tipo_piso.present? %><span class="tag">🔲 <%= quadra.tipo_piso %></span><% end %>
              <% if quadra.tem_iluminacao %><span class="tag">💡 Iluminada</span><% end %>
            </div>

            <!-- Interações da Quadra -->
            <div class="social-actions">
              <div class="action-btn">💬 <%= quadra.comments.count %> Avaliações</div>
              
              <!-- Botão Like para Quadra -->
              <% if current_user.liked?(quadra) %>
                <%= button_to unlike_path("Quadra", quadra.id), method: :delete, class: "action-btn liked", form_class: "inline-form" do %>
                  ❤️ <%= quadra.likes.count %>
                <% end %>
              <% else %>
                <%= button_to like_path("Quadra", quadra.id), method: :post, class: "action-btn", form_class: "inline-form" do %>
                  🤍 <%= quadra.likes.count %> Curtir
                <% end %>
              <% end %>
            </div>

            <!-- Seção de Comentários -->
            <div class="comments-section">
              <!-- Filtramos para mostrar apenas os comentários "Pai" (sem parent_id) -->
              <% quadra.comments.where(parent_id: nil).each do |comment| %>
                <div class="comment-item">
                  <div class="comment-avatar"><%= comment.user.nome.first.upcase rescue "U" %></div>
                  <div class="comment-bubble">
                    <div class="comment-header">
                      <strong><%= comment.user.nome rescue "Usuário" %></strong>
                      <% if comment.nota.present? %><span class="comment-nota">⭐ <%= comment.nota %>/5</span><% end %>
                    </div>
                    
                    <div id="comment-text-<%= comment.id %>" class="comment-text"><%= comment.texto %></div>
                    
                    <% if comment.user == current_user %>
                      <div id="edit-form-<%= comment.id %>" style="display:none; margin-bottom: 0.5rem;">
                        <%= form_with(model: [quadra, comment], local: true, class: "new-comment") do |f| %>
                          <%= f.text_field :texto, class: "form-control", required: true %>
                          <button type="submit" class="btn-send">💾</button>
                        <% end %>
                      </div>
                    <% end %>

                    <div class="post-options" style="display: flex; gap: 0.5rem; align-items: center; margin-top: 0.5rem;">
                      <% if current_user.liked?(comment) %>
                        <%= button_to unlike_path("Comment", comment.id), method: :delete, class: "action-btn liked", form_class: "inline-form", style: "font-size: 0.8rem;" do %>
                          ❤️ <%= comment.likes.count %>
                        <% end %>
                      <% else %>
                        <%= button_to like_path("Comment", comment.id), method: :post, class: "action-btn", form_class: "inline-form", style: "font-size: 0.8rem;" do %>
                          🤍 <%= comment.likes.count %>
                        <% end %>
                      <% end %>

                      <a onclick="document.getElementById('reply-form-<%= comment.id %>').style.display='flex'">Responder</a>
                      
                      <% if comment.user == current_user %>
                        <a onclick="document.getElementById('edit-form-<%= comment.id %>').style.display='block'; document.getElementById('comment-text-<%= comment.id %>').style.display='none';">Editar</a>
                      <% end %>
                      
                      <% if comment.user == current_user || quadra.user == current_user %>
                        <%= link_to 'Apagar', [quadra, comment], data: { turbo_method: :delete }, class: "danger" %>
                      <% end %>
                    </div>

                    <div id="reply-form-<%= comment.id %>" style="display:none;">
                      <%= form_with(model: [quadra, Comment.new], local: true, class: "new-comment", style: "width: 100%;") do |f| %>
                        <%= f.hidden_field :parent_id, value: comment.id %>
                        <%= f.text_field :texto, class: "form-control", placeholder: "Escreva uma resposta...", required: true %>
                        <button type="submit" class="btn-send">➤</button>
                      <% end %>
                    </div>

                    <!-- Respostas -->
                    <% comment.replies.each do |reply| %>
                      <div class="comment-item reply-item">
                        <div class="comment-avatar" style="width: 24px; height: 24px; font-size: 0.6rem;"><%= reply.user.nome.first.upcase rescue "R" %></div>
                        <div class="comment-bubble" style="padding: 0.5rem 0.8rem;">
                          <div class="comment-header"><strong><%= reply.user.nome rescue "Usuário" %></strong></div>
                          
                          <div id="comment-text-<%= reply.id %>" class="comment-text" style="font-size: 0.85rem;"><%= reply.texto %></div>
                          
                          <% if reply.user == current_user %>
                            <div id="edit-form-<%= reply.id %>" style="display:none;">
                              <%= form_with(model: [quadra, reply], local: true, class: "new-comment") do |f| %>
                                <%= f.text_field :texto, class: "form-control", required: true %>
                                <button type="submit" class="btn-send" style="font-size: 0.8rem;">💾</button>
                              <% end %>
                            </div>
                          <% end %>

                          <div class="post-options" style="display: flex; gap: 0.5rem; align-items: center; margin-top: 0.2rem;">
                            <% if current_user.liked?(reply) %>
                              <%= button_to unlike_path("Comment", reply.id), method: :delete, class: "action-btn liked", form_class: "inline-form", style: "font-size: 0.75rem;" do %>
                                ❤️ <%= reply.likes.count %>
                              <% end %>
                            <% else %>
                              <%= button_to like_path("Comment", reply.id), method: :post, class: "action-btn", form_class: "inline-form", style: "font-size: 0.75rem;" do %>
                                🤍 <%= reply.likes.count %>
                              <% end %>
                            <% end %>

                            <% if reply.user == current_user %>
                              <a onclick="document.getElementById('edit-form-<%= reply.id %>').style.display='block'; document.getElementById('comment-text-<%= reply.id %>').style.display='none';">Editar</a>
                            <% end %>
                            <% if reply.user == current_user || quadra.user == current_user %>
                              <%= link_to 'Apagar', [quadra, reply], data: { turbo_method: :delete }, class: "danger" %>
                            <% end %>
                          </div>
                        </div>
                      </div>
                    <% end %>

                  </div>
                </div>
              <% end %>

              <!-- Formulário Inserir Comentário Principal -->
              <%= form_with(model: [quadra, Comment.new], local: true, class: "new-comment") do |f| %>
                <div class="comment-avatar" style="background: var(--orange-primary); color: white;">Você</div>
                <%= f.select :nota, [1, 2, 3, 4, 5], { prompt: "⭐" }, class: "form-control nota-select", required: true %>
                <%= f.text_field :texto, class: "form-control", placeholder: "Escreva sua avaliação...", required: true %>
                <button type="submit" class="btn-send" title="Enviar">➤</button>
              <% end %>

            </div>
          </div>
        </article>
      <% end %>
    <% end %>

  </div>
</body>
</html>