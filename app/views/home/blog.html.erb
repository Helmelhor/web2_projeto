<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Feed Coliseum</title>
  <style>
    /* Variáveis e Reset */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --orange-primary: #FF8C00; --orange-dark: #E67E00; --orange-light: #FFB84D;
      --dark-bg: #0F1419; --card-bg: #1A1F2E; --card-hover: #22283A;
      --text-light: #E0E0E0; --text-muted: #8899A6; --border-color: #2F3336;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background-color: var(--dark-bg); color: var(--text-light); line-height: 1.5;
    }

    /* Navbar estilo Rede Social */
    .navbar {
      background: rgba(15, 20, 25, 0.9); backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border-color);
      position: sticky; top: 0; z-index: 100; padding: 1rem 0;
    }
    .nav-content {
      max-width: 650px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding: 0 1rem;
    }
    .nav-logo { font-size: 1.5rem; font-weight: bold; color: white; text-decoration: none; display: flex; align-items: center; gap: 0.5rem; }

    /* Layout Centralizado (Timeline) */
    .timeline {
      max-width: 650px; margin: 0 auto;
      border-left: 1px solid var(--border-color); border-right: 1px solid var(--border-color);
      min-height: 100vh;
    }

    /* Caixa de "Nova Postagem" */
    .create-post-box {
      padding: 1.5rem; border-bottom: 1px solid var(--border-color);
      background: var(--dark-bg);
    }
    .create-header { display: flex; gap: 1rem; margin-bottom: 1rem; }
    .avatar {
      width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, var(--orange-primary), var(--orange-dark));
      display: flex; align-items: center; justify-content: center; font-size: 1.2rem; font-weight: bold; flex-shrink: 0;
    }
    .create-form-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; flex-grow: 1;
    }
    .full-width { grid-column: span 2; }
    
    .form-control {
      width: 100%; padding: 0.8rem 1rem; background: var(--dark-bg); border: 1px solid var(--border-color);
      border-radius: 12px; color: var(--text-light); font-size: 0.95rem; outline: none; transition: 0.2s;
    }
    .form-control:focus { border-color: var(--orange-primary); }
    textarea.form-control { resize: none; min-height: 60px; }
    
    .create-footer {
      display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; padding-left: calc(48px + 1rem);
    }
    
    .btn {
      padding: 0.6rem 1.5rem; border: none; border-radius: 50px; font-weight: bold; cursor: pointer; transition: 0.2s;
    }
    .btn-primary { background: var(--orange-primary); color: white; }
    .btn-primary:hover { background: var(--orange-dark); }
    
    /* Cartões de Postagem no Feed */
    .post {
      padding: 1.5rem; border-bottom: 1px solid var(--border-color);
      transition: background 0.2s; display: flex; gap: 1rem;
    }
    .post:hover { background: rgba(255, 255, 255, 0.02); }
    
    .post-content { flex-grow: 1; min-width: 0; }
    
    .post-author-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
    .author-name { font-weight: bold; font-size: 1rem; color: white; display: flex; align-items: center; gap: 0.5rem; }
    .author-handle { color: var(--text-muted); font-weight: normal; font-size: 0.9rem; }
    
    .post-options a { color: var(--text-muted); text-decoration: none; font-size: 0.8rem; margin-left: 0.8rem; }
    .post-options a:hover { color: var(--orange-primary); }
    .post-options a.danger:hover { color: #f4212e; }

    .post-text { font-size: 0.95rem; margin-bottom: 1rem; white-space: pre-wrap; }
    
    .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
    .tag { background: rgba(255, 140, 0, 0.1); color: var(--orange-primary); padding: 0.2rem 0.8rem; border-radius: 20px; font-size: 0.8rem; font-weight: 500; border: 1px solid rgba(255, 140, 0, 0.2); }

    /* Barra de Ações Sociais (Curtir, Comentar) */
    .social-actions {
      display: flex; justify-content: space-between; max-width: 400px; margin-top: 1rem; color: var(--text-muted);
    }
    .action-btn { display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; cursor: pointer; transition: color 0.2s; }
    .action-btn:hover { color: var(--orange-primary); }

    /* Comentários (Estilo Chat) */
    .comments-section {
      margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px dashed var(--border-color);
    }
    
    .comment-item { display: flex; gap: 0.8rem; margin-bottom: 1rem; }
    .comment-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--card-hover); display: flex; align-items: center; justify-content: center; font-size: 0.8rem; }
    .comment-bubble {
      background: var(--card-hover); padding: 0.8rem 1rem; border-radius: 0 15px 15px 15px; flex-grow: 1;
    }
    .comment-header { display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 0.3rem; }
    .comment-header strong { color: white; }
    .comment-nota { color: var(--orange-primary); font-weight: bold; }
    .comment-text { font-size: 0.9rem; color: var(--text-light); }

    /* Input de Comentário novo */
    .new-comment { display: flex; gap: 0.5rem; margin-top: 1rem; align-items: center; }
    .new-comment .form-control { border-radius: 50px; padding: 0.6rem 1.2rem; background: var(--card-bg); }
    .new-comment .nota-select { width: 80px; border-radius: 50px; }
    .btn-send { background: transparent; border: none; color: var(--orange-primary); font-size: 1.2rem; cursor: pointer; padding: 0.5rem; border-radius: 50%; transition: 0.2s;}
    .btn-send:hover { background: rgba(255, 140, 0, 0.1); }
  </style>
</head>
<body>

  <nav class="navbar">
    <div class="nav-content">
      <a href="/home/index" class="nav-logo">🏀 Coliseum</a>
      <a href="/home/index" class="btn btn-primary" style="padding: 0.4rem 1rem; font-size: 0.9rem;">Voltar</a>
    </div>
  </nav>

  <div class="timeline">
    
    <div class="create-post-box">
      <div class="create-header">
        <div class="avatar">U</div> <%= form_with(model: @quadra || Quadra.new, local: true, class: "full-width") do |f| %>
          <div class="create-form-grid">
            <div class="full-width">
              <%= f.text_field :nome, class: "form-control", placeholder: "Qual o nome da quadra?", required: true %>
            </div>
            <div>
              <%= f.text_field :endereco, class: "form-control", placeholder: "Endereço" %>
            </div>
            <div>
              <%= f.text_field :cidade, class: "form-control", placeholder: "Cidade" %>
            </div>
            <div class="full-width">
              <%= f.text_area :descricao, class: "form-control", placeholder: "Descreva as condições da quadra, horários, etc..." %>
            </div>
            <div>
              <%= f.text_field :tipo_piso, class: "form-control", placeholder: "Piso (Ex: Asfalto)" %>
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem; padding-left: 0.5rem; color: var(--text-muted); font-size: 0.9rem;">
              <%= f.check_box :tem_iluminacao %>
              <%= f.label :tem_iluminacao, "Tem iluminação?" %>
            </div>
          </div>
          
          <div class="create-footer">
            <div style="color: var(--orange-primary); cursor: pointer; font-size: 1.2rem;" title="Adicionar Foto">
              📷 </div>
            <%= f.submit "Postar", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>

    <% if @quadras.present? %>
      <% @quadras.order(created_at: :desc).each do |quadra| %>
        <article class="post">
          <div class="avatar">
            <%= quadra.nome.first.upcase rescue "Q" %>
          </div>
          
          <div class="post-content">
            <div class="post-author-row">
              <div class="author-name">
                <%= quadra.nome %>
                <span class="author-handle">📍 <%= quadra.cidade %></span>
                <span class="author-handle">· <%= time_ago_in_words(quadra.created_at) %> atrás</span>
              </div>
              
              <div class="post-options">
                <%= link_to 'Editar', edit_quadra_path(quadra) %>
                <%= link_to 'Excluir', quadra, data: { turbo_method: :delete, turbo_confirm: 'Deseja apagar este post?' }, class: "danger" %>
              </div>
            </div>

            <div class="post-text">
              <%= quadra.descricao %>
            </div>

            <div class="post-tags">
              <span class="tag">🛣️ <%= quadra.endereco %></span>
              <% if quadra.tipo_piso.present? %>
                <span class="tag">🔲 <%= quadra.tipo_piso %></span>
              <% end %>
              <% if quadra.tem_iluminacao %>
                <span class="tag">💡 Iluminada</span>
              <% end %>
            </div>

            <div class="social-actions">
              <div class="action-btn">💬 <%= quadra.comments.count %> Avaliações</div>
              <div class="action-btn">🔁 Compartilhar</div>
              <div class="action-btn">❤️ Curtir</div>
            </div>

            <div class="comments-section">
              <% quadra.comments.each do |comment| %>
                <div class="comment-item">
                  <div class="comment-avatar"><%= comment.user.nome.first.upcase rescue "U" %></div>
                  <div class="comment-bubble">
                    <div class="comment-header">
                      <strong><%= comment.user.nome rescue "Usuário" %></strong>
                      <span class="comment-nota">⭐ <%= comment.nota %>/5</span>
                    </div>
                    <div class="comment-text"><%= comment.texto %></div>
                    
                    <div style="margin-top: 0.5rem; text-align: right;">
                      <%= link_to 'Apagar', [quadra, comment], data: { turbo_method: :delete }, style: "color: #f4212e; font-size: 0.75rem; text-decoration: none;" %>
                    </div>
                  </div>
                </div>
              <% end %>

              <%= form_with(model: [quadra, Comment.new], local: true, class: "new-comment") do |f| %>
                <div class="comment-avatar" style="background: var(--orange-primary); color: white;">Você</div>
                
                <%= f.select :nota, [1, 2, 3, 4, 5], { prompt: "⭐" }, class: "form-control nota-select", required: true %>
                <%= f.text_field :texto, class: "form-control", placeholder: "Escreva sua avaliação...", required: true %>
                
                <% if session[:user_id] %>
                  <%= f.hidden_field :user_id, value: session[:user_id] %>
                <% end %>

                <button type="submit" class="btn-send" title="Enviar">➤</button>
              <% end %>
            </div>

          </div>
        </article>
      <% end %>
    <% else %>
      <div style="padding: 3rem; text-align: center; color: var(--text-muted);">
        <h2>O feed está vazio</h2>
        <p>Seja o primeiro a compartilhar uma quadra na sua região!</p>
      </div>
    <% end %>

  </div>

</body>
</html>