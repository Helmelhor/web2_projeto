#!/bin/bash
set -e

# Remove o arquivo PID caso o container anterior tenha fechado de forma suja
rm -f /rails/tmp/pids/server.pid

# Função para esperar o banco de dados ficar pronto
echo "Aguardando o banco de dados (PostgreSQL) inicializar..."
until pg_isready -h "$DATABASE_HOST" -U "$DATABASE_USER"; do
  echo "Banco de dados indisponível, tentando novamente em 2 segundos..."
  sleep 2
done
echo "Banco de dados pronto!"

# Prepara o banco (cria e roda migrations)
echo "Preparando o banco de dados..."
bundle exec rails db:prepare

# Executa o comando passado para o container
exec "$@"